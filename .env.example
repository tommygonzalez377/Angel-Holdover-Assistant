# Copy this file to .env and fill in your credentials

# Comscore (Box Office Essentials)
COMSCORE_USERNAME=your_comscore_username
COMSCORE_PASSWORD=your_comscore_password

# Mica credentials
MICA_USERNAME=your_mica_email
MICA_PASSWORD=your_mica_password

# AI Labs API key — used to parse booking sheet screenshots via Claude vision
# Shared key — no per-user setup needed
AI_LABS_API_KEY=your_ai_labs_api_key

# Database (PostgreSQL for production, leave blank to use SQLite locally)
DATABASE_URL=

# Google OAuth (for user login)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_ALLOWED_DOMAIN=angel.com
SECRET_KEY=generate_a_random_secret_key_here

# Server mode — set to "1" when deployed, leave blank for local
SERVER_MODE=

# Optional: custom paths for logo/video assets
# Defaults to assets/logo.eps and assets/bg_video.mp4 next to launcher.py
# VIDEO_PATH=C:\path\to\bg_video.mp4
# LOGO_PATH=C:\path\to\logo.eps
